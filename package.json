  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^2.3.0",
    "autoprefixer": "^9.8.0",
    "concurrently": "^5.2.0",
    "cssnano": "^4.1.10",
    "postcss-cli": "^7.1.1",
